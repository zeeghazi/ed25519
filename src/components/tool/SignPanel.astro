---
import Button from '../ui/Button.astro'
import CopyButton from './CopyButton.astro'

interface Props {
	standalone?: boolean
}
const { standalone = false } = Astro.props

const command =
	'[user@ubuntu ~]$ ./sign --message="Hello World" --private-key=hex'
---

<div
	data-panel="sign"
	role={standalone ? undefined : 'tabpanel'}
	aria-labelledby={standalone ? undefined : 'tab-sign'}
	hidden={standalone ? undefined : true}
>
	<p
		class="font-mono text-sm leading-relaxed text-[var(--color-term-accent)]"
	>
		{command}
	</p>
	<p class="mt-2 max-w-prose text-sm text-[var(--color-term-dim)]">
		Produce an EdDSA signature with your private key.
	</p>

	<div class="mt-5 space-y-4">
		<div>
			<label
				for="sign-message"
				class="font-mono text-xs tracking-[0.12em] text-[var(--color-term-dim)] uppercase"
				>Message</label
			>
			<textarea
				id="sign-message"
				rows="3"
				class="mt-1.5 w-full rounded-[4px] border border-[var(--color-term-border)] bg-[var(--color-term-bg-2)] p-3 font-mono text-sm text-[var(--color-term-fg)] placeholder:text-[var(--color-term-dim)] focus:border-[var(--color-term-accent)] focus:outline-none"
				placeholder="Type a message to sign…"></textarea>
		</div>
		<div>
			<label
				for="sign-private"
				class="font-mono text-xs tracking-[0.12em] text-[var(--color-term-dim)] uppercase"
				>Private key · 64 hex</label
			>
			<input
				id="sign-private"
				type="text"
				class="mt-1.5 w-full rounded-[4px] border border-[var(--color-term-border)] bg-[var(--color-term-bg-2)] p-3 font-mono text-sm text-[var(--color-term-fg)] placeholder:text-[var(--color-term-dim)] focus:border-[var(--color-term-accent)] focus:outline-none"
				placeholder="Paste your 64-hex private key…"
			/>
		</div>
	</div>

	<Button id="sign-btn" variant="prompt" class="mt-5">Sign message</Button>

	<div class="mt-6">
		<label
			class="font-mono text-xs tracking-[0.12em] text-[var(--color-term-dim)] uppercase"
			>Signature · 128 hex</label
		>
		<div
			class="mt-1.5 flex items-start gap-3 rounded-[4px] border border-[var(--color-term-border)] bg-[var(--color-term-bg-2)] p-3"
		>
			<span
				class="mt-px shrink-0 font-mono text-sm text-[var(--color-term-prompt)]"
				aria-hidden="true">sig</span
			>
			<output
				id="sign-output"
				class="block w-full font-mono text-sm break-all text-[var(--color-term-fg)]"
				>—</output
			>
			<CopyButton target="#sign-output" label="Copy signature" />
		</div>
	</div>
</div>

<script>
	import { signMessage } from '../../lib/ed25519'
	import { toast } from '../../lib/clipboard'

	const btn = document.getElementById('sign-btn') as HTMLButtonElement | null
	const msg = document.getElementById(
		'sign-message'
	) as HTMLTextAreaElement | null
	const priv = document.getElementById(
		'sign-private'
	) as HTMLInputElement | null
	const out = document.getElementById('sign-output')

	btn?.addEventListener('click', async () => {
		if (!msg?.value.trim()) {
			toast('Enter a message', 'error')
			return
		}
		if (!priv?.value.trim()) {
			toast('Enter a private key', 'error')
			return
		}
		btn.disabled = true
		btn.textContent = 'Signing…'
		try {
			const sig = await signMessage(msg.value, priv.value.trim())
			if (out) out.textContent = sig
			toast('Message signed')
		} catch (e) {
			toast(e instanceof Error ? e.message : 'Failed to sign', 'error')
		} finally {
			btn.disabled = false
			btn.textContent = 'Sign message'
		}
	})
</script>
