---
import Button from '../ui/Button.astro'
import CopyButton from './CopyButton.astro'

interface Props {
	standalone?: boolean
}
const { standalone = false } = Astro.props

const command = '[user@ubuntu ~]$ ./keygen --curve=edwards25519 --format=hex'
---

<div
	data-panel="generate"
	role={standalone ? undefined : 'tabpanel'}
	aria-labelledby={standalone ? undefined : 'tab-generate'}
>
	<p
		class="font-mono text-sm leading-relaxed text-[var(--color-term-accent)]"
	>
		{command}
	</p>
	<p class="mt-2 max-w-prose text-sm text-[var(--color-term-dim)]">
		Generates a cryptographically secure Ed25519 keypair locally via
		WebCrypto. The private key never leaves this page.
	</p>

	<Button id="keygen-btn" variant="prompt" class="mt-5"
		>Generate keypair</Button
	>

	<div class="mt-6 space-y-3">
		<div>
			<label
				class="font-mono text-xs tracking-[0.12em] text-[var(--color-term-dim)] uppercase"
				>Public key · 64 hex</label
			>
			<div
				class="mt-1.5 flex items-start gap-3 rounded-[4px] border border-[var(--color-term-border)] bg-[var(--color-term-bg-2)] p-3"
			>
				<span
					class="mt-px shrink-0 font-mono text-sm text-[var(--color-term-prompt)]"
					aria-hidden="true">pub</span
				>
				<output
					id="keygen-public"
					class="block w-full font-mono text-sm break-all text-[var(--color-term-fg)]"
					>—</output
				>
				<CopyButton target="#keygen-public" label="Copy public key" />
			</div>
		</div>
		<div>
			<label
				class="font-mono text-xs tracking-[0.12em] text-[var(--color-term-dim)] uppercase"
				>Private key · 64 hex · <span
					class="text-[var(--color-term-danger)]">keep secret</span
				></label
			>
			<div
				class="mt-1.5 flex items-start gap-3 rounded-[4px] border border-[var(--color-term-border)] bg-[var(--color-term-bg-2)] p-3"
			>
				<span
					class="mt-px shrink-0 font-mono text-sm text-[var(--color-term-danger)]"
					aria-hidden="true">priv</span
				>
				<output
					id="keygen-private"
					class="block w-full font-mono text-sm break-all text-[var(--color-term-fg)]"
					>—</output
				>
				<CopyButton target="#keygen-private" label="Copy private key" />
			</div>
		</div>
	</div>
</div>

<script>
	import { generateKeypair } from '../../lib/ed25519'
	import { toast } from '../../lib/clipboard'

	const btn = document.getElementById(
		'keygen-btn'
	) as HTMLButtonElement | null
	const pub = document.getElementById('keygen-public')
	const priv = document.getElementById('keygen-private')

	btn?.addEventListener('click', async () => {
		btn.disabled = true
		btn.textContent = 'Generating…'
		try {
			const { privateKeyHex, publicKeyHex } = await generateKeypair()
			if (pub) pub.textContent = publicKeyHex
			if (priv) priv.textContent = privateKeyHex
			toast('Keypair generated')
		} catch {
			toast('Failed to generate keypair', 'error')
		} finally {
			btn.disabled = false
			btn.textContent = 'Generate keypair'
		}
	})
</script>
