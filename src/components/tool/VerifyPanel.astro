---
import Button from '../ui/Button.astro'

interface Props {
	standalone?: boolean
}
const { standalone = false } = Astro.props
---

<div
	data-panel="verify"
	role={standalone ? undefined : 'tabpanel'}
	aria-labelledby={standalone ? undefined : 'tab-verify'}
	hidden={standalone ? undefined : true}
>
	<p class="font-mono text-xs text-[var(--color-term-dim)]">
		<span class="text-[var(--color-term-prompt)]">$</span> ed25519 verify --pub
		&lt;key&gt; --sig &lt;sig&gt;
	</p>
	<p class="mt-2 max-w-prose text-sm text-[var(--color-term-dim)]">
		Check a signature against the original message and a public key.
	</p>

	<div class="mt-5 space-y-4">
		<div>
			<label
				for="verify-message"
				class="font-mono text-[11px] tracking-[0.12em] text-[var(--color-term-dim)] uppercase"
				>Original message</label
			>
			<textarea
				id="verify-message"
				rows="3"
				class="mt-1.5 w-full rounded-[4px] border border-[var(--color-term-border)] bg-[var(--color-term-bg-2)] p-3 font-mono text-sm text-[var(--color-term-fg)] placeholder:text-[var(--color-term-dim)] focus:border-[var(--color-term-accent)] focus:outline-none"
				placeholder="The exact message that was signed…"></textarea>
		</div>
		<div>
			<label
				for="verify-public"
				class="font-mono text-[11px] tracking-[0.12em] text-[var(--color-term-dim)] uppercase"
				>Public key · 64 hex</label
			>
			<input
				id="verify-public"
				type="text"
				class="mt-1.5 w-full rounded-[4px] border border-[var(--color-term-border)] bg-[var(--color-term-bg-2)] p-3 font-mono text-xs text-[var(--color-term-fg)] placeholder:text-[var(--color-term-dim)] focus:border-[var(--color-term-accent)] focus:outline-none"
				placeholder="Paste the 64-hex public key…"
			/>
		</div>
		<div>
			<label
				for="verify-signature"
				class="font-mono text-[11px] tracking-[0.12em] text-[var(--color-term-dim)] uppercase"
				>Signature · 128 hex</label
			>
			<textarea
				id="verify-signature"
				rows="2"
				class="mt-1.5 w-full rounded-[4px] border border-[var(--color-term-border)] bg-[var(--color-term-bg-2)] p-3 font-mono text-xs text-[var(--color-term-fg)] placeholder:text-[var(--color-term-dim)] focus:border-[var(--color-term-accent)] focus:outline-none"
				placeholder="Paste the 128-hex signature…"></textarea>
		</div>
	</div>

	<Button id="verify-btn" variant="prompt" class="mt-5"
		>Verify signature</Button
	>

	<div
		id="verify-result"
		class="mt-6 rounded-[4px] border border-[var(--color-term-border)] bg-[var(--color-term-bg-2)] p-4 font-mono text-sm text-[var(--color-term-dim)]"
	>
		<span class="text-[var(--color-term-dim)]">// awaiting input…</span>
	</div>
</div>

<script>
	import { verifySignature } from '../../lib/ed25519'
	import { toast } from '../../lib/clipboard'

	const btn = document.getElementById(
		'verify-btn'
	) as HTMLButtonElement | null
	const msg = document.getElementById(
		'verify-message'
	) as HTMLTextAreaElement | null
	const pub = document.getElementById(
		'verify-public'
	) as HTMLInputElement | null
	const sig = document.getElementById(
		'verify-signature'
	) as HTMLTextAreaElement | null
	const result = document.getElementById('verify-result')

	btn?.addEventListener('click', async () => {
		if (!msg?.value.trim() || !pub?.value.trim() || !sig?.value.trim()) {
			toast('Fill message, public key, and signature', 'error')
			return
		}
		btn.disabled = true
		btn.textContent = 'Verifying…'
		try {
			const ok = await verifySignature(
				sig.value.trim(),
				msg.value,
				pub.value.trim()
			)
			if (result) {
				result.textContent = ok
					? '✓ VALID — signature matches.'
					: '✗ INVALID — signature does not match.'
				result.className =
					'mt-6 rounded-[4px] border p-4 font-mono text-sm ' +
					(ok
						? 'border-[#2dd4a87a] bg-[#2dd4a814] text-[var(--color-term-prompt)]'
						: 'border-[#ff6b817a] bg-[#ff6b8114] text-[var(--color-term-danger)]')
			}
			toast(
				ok ? 'Signature valid' : 'Signature invalid',
				ok ? 'success' : 'error'
			)
		} catch (e) {
			toast(e instanceof Error ? e.message : 'Failed to verify', 'error')
		} finally {
			btn.disabled = false
			btn.textContent = 'Verify signature'
		}
	})
</script>
