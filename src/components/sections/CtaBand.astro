---
import Button from '../ui/Button.astro'
---

<section class="px-4 pb-20 sm:px-6">
	<div
		class="console-shadow relative mx-auto max-w-[1200px] overflow-hidden rounded-[12px] border border-[var(--color-term-border)] bg-[var(--color-term-bg)] px-6 py-16 text-center sm:px-6"
	>
		<div
			class="mesh-gradient pointer-events-none absolute inset-0 -z-0 opacity-20 blur-[90px]"
			aria-hidden="true"
		>
		</div>
		<div class="relative">
			<p class="font-mono text-xs text-[var(--color-term-dim)]">
				<span class="text-[var(--color-term-prompt)]">$</span> ed25519 generate
			</p>
			<h2
				class="display-lg mx-auto mt-4 max-w-2xl text-[var(--color-term-fg)]"
			>
				Try the Ed25519 tool now.
			</h2>
			<p
				class="mx-auto mt-3 max-w-lg text-base text-[var(--color-term-dim)]"
			>
				Generate a keypair and sign your first message in seconds — no
				signup, no server.
			</p>
			<div class="mt-8">
				<Button href="/#tool" variant="prompt">Open the tool</Button>
			</div>
		</div>
	</div>
</section>
