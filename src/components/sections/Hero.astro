---
import Badge from '../ui/Badge.astro'

const facts = ['no signup', 'no server', '100% client-side', 'open source']
---

<!--
	Hero content only. The continuous grid + glow backdrop it sits on is a single
	pinned layer shared with the tool (see index.astro), so the two read as one
	background. This block scrolls over that pinned backdrop.
-->
<section class="flex min-h-[78svh] items-center">
	<div class="mx-auto w-full max-w-[940px] px-4 py-16 text-center sm:px-6">
		<Badge dot>client-side EdDSA toolkit</Badge>

		<h1 class="display-xl mx-auto mt-5 max-w-3xl text-balance">
			Generate, sign &amp; verify Ed25519 keys.<span
				class="term-caret"
				aria-hidden="true"></span>
		</h1>

		<p class="text-body mx-auto mt-5 max-w-xl text-lg text-balance">
			A fast, private toolkit for modern digital signatures — RFC 8032
			EdDSA, computed entirely in your browser. Your private keys never
			touch a server.
		</p>

		<ul
			class="text-mute mt-7 flex flex-wrap items-center justify-center gap-x-5 gap-y-2 font-mono text-xs"
		>
			{
				facts.map((f) => (
					<li class="inline-flex items-center gap-1.5">
						<span
							class="text-[var(--color-term-prompt)]"
							aria-hidden="true"
						>
							✓
						</span>
						{f}
					</li>
				))
			}
		</ul>
	</div>
</section>
