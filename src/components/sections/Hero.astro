---
import Badge from '../ui/Badge.astro'

const facts = ['no signup', 'no server', '100% client-side', 'open source']
---

<!--
	Hero content only. The continuous grid + glow backdrop it sits on is a single
	pinned layer shared with the tool (see index.astro). Editorial split layout:
	headline left, description right; badge on top, facts row on the bottom.
-->
<section class="flex min-h-[60svh] items-center px-4 sm:px-6">
	<div class="mx-auto w-full max-w-[1200px]">
		<Badge dot>client-side EdDSA toolkit</Badge>

		<div class="mt-7 grid gap-6 md:grid-cols-2 md:items-start md:gap-12">
			<h1 class="display-xl">
				Cryptographic trust.<br />
				Instantly <span id="tw-wrap" class="inline-block text-left"
					><span id="tw-word" class="text-[var(--color-term-prompt)]"
						>generate</span
					><span class="term-caret" aria-hidden="true"></span></span
				>
			</h1>
			<p
				class="text-body md:border-hairline max-w-md text-lg leading-relaxed md:border-l md:pt-1.5 md:pl-8"
			>
				A fast, private toolkit for modern digital signatures — RFC 8032
				EdDSA, computed entirely in your browser. Your private keys
				never touch a server.
			</p>
		</div>

		<ul
			class="text-body mt-9 flex flex-wrap items-center gap-x-6 gap-y-2.5 font-mono text-sm"
		>
			{
				facts.map((f) => (
					<li class="inline-flex items-center gap-2">
						<svg
							class="h-[18px] w-[18px] shrink-0 text-[var(--color-term-prompt)]"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="3"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<path d="M20 6 9 17l-5-5" />
						</svg>
						{f}
					</li>
				))
			}
		</ul>
	</div>
</section>

<script>
	// Typewriter cycle for the last headline word: generate → sign → verify → …
	// The wrapper is pinned to the widest word's width so the line never reflows.
	const el = document.getElementById('tw-word')
	const wrap = document.getElementById('tw-wrap')
	const words = ['generate', 'sign', 'verify']

	if (el && wrap) {
		// Reserve width = widest word so "sign"/"verify" don't shrink the line.
		let max = 0
		for (const w of words) {
			el.textContent = w
			max = Math.max(max, el.offsetWidth)
		}
		wrap.style.minWidth = `${Math.ceil(max) + 12}px`
		el.textContent = words[0]

		const reduce = window.matchMedia(
			'(prefers-reduced-motion: reduce)'
		).matches
		if (!reduce) {
			let wi = 0
			let ci = words[0].length
			let deleting = false
			const tick = () => {
				const word = words[wi]
				if (!deleting && ci === word.length) {
					deleting = true
					setTimeout(tick, 1500)
					return
				}
				if (deleting && ci === 0) {
					deleting = false
					wi = (wi + 1) % words.length
					setTimeout(tick, 280)
					return
				}
				ci += deleting ? -1 : 1
				el.textContent = words[wi].slice(0, ci)
				setTimeout(tick, deleting ? 80 : 135)
			}
			setTimeout(tick, 1500)
		}
	}
</script>
