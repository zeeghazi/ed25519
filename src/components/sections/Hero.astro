---
import Badge from '../ui/Badge.astro'

const facts = ['no signup', 'no server', '100% client-side', 'open source']
---

<!--
	Hero content only. The continuous grid + glow backdrop it sits on is a single
	pinned layer shared with the tool (see index.astro). Editorial split layout:
	headline left, description right; badge on top, facts row on the bottom.
-->
<section class="flex min-h-[60svh] items-center px-4 sm:px-6">
	<div class="mx-auto w-full max-w-[1100px]">
		<Badge dot>client-side EdDSA toolkit</Badge>

		<div class="mt-7 grid gap-6 md:grid-cols-2 md:items-start md:gap-12">
			<h1 class="display-xl">
				Cryptographic trust.<br />
				Instantly <span
					id="tw-word"
					class="text-[var(--color-term-prompt)]">generate</span
				><span class="term-caret" aria-hidden="true"></span>
			</h1>
			<p
				class="text-body md:border-hairline max-w-md text-base leading-relaxed md:border-l md:pt-1.5 md:pl-8"
			>
				A fast, private toolkit for modern digital signatures — RFC 8032
				EdDSA, computed entirely in your browser. Your private keys
				never touch a server.
			</p>
		</div>

		<ul
			class="text-mute mt-9 flex flex-wrap items-center gap-x-5 gap-y-2 font-mono text-xs"
		>
			{
				facts.map((f) => (
					<li class="inline-flex items-center gap-1.5">
						<span
							class="text-[var(--color-term-prompt)]"
							aria-hidden="true"
						>
							✓
						</span>
						{f}
					</li>
				))
			}
		</ul>
	</div>
</section>

<script>
	// Typewriter cycle for the last headline word: generate → sign → verify → …
	const el = document.getElementById('tw-word')
	const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
	if (el && !reduce) {
		const words = ['generate', 'sign', 'verify']
		let wi = 0
		let ci = words[0].length
		let deleting = false
		const tick = () => {
			const word = words[wi]
			if (!deleting && ci === word.length) {
				deleting = true
				setTimeout(tick, 1500)
				return
			}
			if (deleting && ci === 0) {
				deleting = false
				wi = (wi + 1) % words.length
				setTimeout(tick, 280)
				return
			}
			ci += deleting ? -1 : 1
			el.textContent = words[wi].slice(0, ci)
			setTimeout(tick, deleting ? 55 : 100)
		}
		setTimeout(tick, 1500)
	}
</script>
