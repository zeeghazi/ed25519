---
interface Props {
	variant?: 'primary' | 'secondary' | 'ghost' | 'prompt' | 'terminal'
	size?: 'sm' | 'md'
	href?: string
	type?: 'button' | 'submit'
	class?: string
	id?: string
}
const {
	variant = 'primary',
	size = 'md',
	href,
	type = 'button',
	class: cls = '',
	id,
} = Astro.props
const base =
	'group inline-flex select-none items-center justify-center gap-2 rounded-[4px] font-mono font-medium uppercase tracking-[0.08em] transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50'
const sizes = {
	sm: 'h-8 px-3 text-[11px]',
	md: 'h-10 px-4 text-xs',
}[size]
const styles = {
	primary:
		'bg-ink text-on-primary hover:bg-ink/85 focus-visible:ring-ink/40 focus-visible:ring-offset-canvas',
	secondary:
		'border border-hairline-strong/50 bg-transparent text-ink hover:border-ink hover:bg-canvas-soft-2 focus-visible:ring-ink/30 focus-visible:ring-offset-canvas',
	ghost: 'bg-transparent text-body hover:text-ink focus-visible:ring-ink/20 focus-visible:ring-offset-canvas',
	prompt: 'bg-[var(--color-term-prompt)] text-[var(--color-term-bg)] hover:brightness-110 focus-visible:ring-[var(--color-term-prompt)]/50 focus-visible:ring-offset-[var(--color-term-bg)]',
	terminal:
		'border border-[var(--color-term-border)] bg-[var(--color-term-bg-2)] text-[var(--color-term-fg)] hover:border-[var(--color-term-prompt)] hover:text-[var(--color-term-prompt)] focus-visible:ring-[var(--color-term-accent)]/50 focus-visible:ring-offset-[var(--color-term-bg)]',
}[variant]
const klass = `${base} ${sizes} ${styles} ${cls}`
---

{
	href ? (
		<a href={href} class={klass} id={id}>
			<slot />
		</a>
	) : (
		<button type={type} class={klass} id={id}>
			<slot />
		</button>
	)
}
